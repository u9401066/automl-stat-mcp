# AutoML Stack Environment Variables
#
# Setup:
#   1. Copy this file to .env: cp .env.example .env
#   2. Keep STORAGE_MODE=local for the default local-first stack
#   3. Only fill MinIO values when you actually use STORAGE_MODE=minio
#
# ⚠️ NEVER commit the .env file to git!

# =============================================================================
# Core Runtime
# =============================================================================
# local  -> use local /data mounts only
# minio  -> use external or profile=full MinIO object storage
STORAGE_MODE=local

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Number of worker containers (used by docs / manual scaling)
WORKER_REPLICAS=4

# =============================================================================
# MinIO (optional unless STORAGE_MODE=minio)
# =============================================================================
# Example: minio.example.com:9000 or minio:9000 when using docker compose --profile full
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_DATASET_BUCKET=automl-datasets
MINIO_MODEL_BUCKET=automl-models
MINIO_REPORTS_BUCKET=stats-reports

# =============================================================================
# HTTPS Deployment (for docker-compose.https.yml)
# =============================================================================
# SSL certificate paths (relative to project root or absolute)
# SSL_CERT_PATH=./nginx/ssl
# SSL_KEY_PATH=./nginx/ssl

# External ports
# HTTPS_PORT=443
# HTTP_PORT=80
