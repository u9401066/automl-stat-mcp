# AutoML Stack Environment Variables
#
# Setup:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Edit .env with your actual values
#   3. Run: docker-compose up -d
#
# ⚠️ NEVER commit the .env file to git!

# =============================================================================
# MinIO Connection (REQUIRED - Your existing MinIO server)
# =============================================================================
# Example: minio.example.com:9000 or 10.0.0.100:9000
MINIO_ENDPOINT=your-minio-host:9000

# Your MinIO credentials (create via MinIO Console or mc admin)
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key

# Use HTTPS? (set to true if your MinIO uses TLS)
MINIO_SECURE=false

# Bucket names (will be created automatically if they don't exist)
MINIO_DATASET_BUCKET=automl-datasets
MINIO_MODEL_BUCKET=automl-models

# =============================================================================
# Optional Settings
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Number of worker containers (default: 4)
WORKER_REPLICAS=4

# =============================================================================
# HTTPS Deployment (for docker-compose.https.yml)
# =============================================================================
# SSL certificate paths (relative to project root or absolute)
# SSL_CERT_PATH=./nginx/ssl
# SSL_KEY_PATH=./nginx/ssl

# External ports
# HTTPS_PORT=443
# HTTP_PORT=80
